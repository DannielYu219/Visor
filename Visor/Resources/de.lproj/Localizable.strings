/* ===== Werkzeugbeschreibungen (an LLM gesendet) ===== */
"tool.desc.fileWrite" = "Schreibe oder überschreibe eine Datei im Arbeitsverzeichnis der aktuellen Session. Der Pfad ist relativ zur Session-Wurzel, z. B. \"index.html\", \"assets/style.css\".\nDient dazu, Design-Artefakte (HTML/CSS/JS) im Dateisystem zu persistieren; die Canvas aktualisiert sich in Echtzeit.\nNur bei neuen Dateien oder ausdrücklichem Wunsch des Nutzers nach komplettem Refactor verwenden; zum Ändern bestehender Dateien bevorzugt file_patch verwenden, um Token zu sparen.";
"tool.desc.fileWrite.path" = "Relativer Pfad, z. B. index.html";
"tool.desc.fileWrite.content" = "UTF-8-Textinhalt";
"tool.desc.filePatch" = "Lokales Ersetzen eines Teils des Inhalts einer bestehenden Datei (SEARCH/REPLACE). Für das Ändern bestehender Dateien bevorzugt verwenden; spart erheblich Token und beschleunigt die Antwort.\nÜbergib den zu suchenden Originaltext als `search` und den neuen Inhalt als `replace`; das Werkzeug lokalisiert `search` in der Datei und ersetzt ihn durch `replace`.\n`search` muss eindeutig matchen (0 oder mehrere Treffer schlagen fehl; füge mehr Kontextzeilen hinzu, um es eindeutig zu machen).\nEin leerer `replace`-String löscht den `search`-Block.";
"tool.desc.filePatch.path" = "Relativer Pfad, z. B. index.html";
"tool.desc.filePatch.search" = "Zu suchender und zu ersetzender Originaltext; muss ein exaktes Snippet aus der Datei sein (inkl. Einrückung/Zeilenumbrüchen) und eindeutig";
"tool.desc.filePatch.replace" = "Neuer Inhalt; leerer String löscht den search-Block";
"tool.desc.fileRead" = "Lies eine Datei aus dem Arbeitsverzeichnis der Session und gib den UTF-8-Textinhalt zurück.";
"tool.desc.fileRead.path" = "Relativer Pfad";
"tool.desc.fileList" = "Liste alle Dateien im Arbeitsverzeichnis der Session auf (inkl. Unterverzeichnisse) und gib ein JSON-Array zurück.";
"tool.desc.fileRemove" = "Lösche eine Datei.";
