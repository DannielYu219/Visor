/* ===== Tool descriptions (sent to LLM) ===== */
"tool.desc.fileWrite" = "Write or overwrite a file in the current session's working directory. Path is relative to the session root, e.g. \"index.html\", \"assets/style.css\".\nUsed to persist design artifacts (HTML/CSS/JS) to the filesystem; the canvas refreshes in real time.\nUse only when creating new files or when the user explicitly requests a full refactor; prefer file_patch to modify existing files and save tokens.";
"tool.desc.fileWrite.path" = "Relative path, e.g. index.html";
"tool.desc.fileWrite.content" = "UTF-8 text content";
"tool.desc.filePatch" = "Locally replace part of an existing file's content (SEARCH/REPLACE). Prefer this tool for modifying existing files; it greatly saves tokens and speeds up response.\nPass the original text to find as `search` and the new content as `replace`; the tool locates `search` in the file and replaces it with `replace`.\n`search` must match uniquely (0 or multiple matches will fail; add more context lines to make it unique).\nAn empty `replace` string deletes the `search` block.";
"tool.desc.filePatch.path" = "Relative path, e.g. index.html";
"tool.desc.filePatch.search" = "Original text to find and replace; must be an exact snippet from the file (including indentation/newlines) and unique";
"tool.desc.filePatch.replace" = "New content; empty string deletes the search block";
"tool.desc.fileRead" = "Read a file from the session's working directory, returning UTF-8 text content.";
"tool.desc.fileRead.path" = "Relative path";
"tool.desc.fileList" = "List all files in the session's working directory (including subdirectories), returning a JSON array.";
"tool.desc.fileRemove" = "Delete a file.";
"tool.desc.fileRemove.path" = "Relative path";
"tool.desc.fileMkdir" = "Create a subdirectory (supports nested paths).";
"tool.desc.fileMkdir.path" = "Relative path";
