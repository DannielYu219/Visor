/* ===== Descriptions d'outils (envoyées au LLM) ===== */
"tool.desc.fileWrite" = "Écrire ou écraser un fichier dans le répertoire de travail de la session courante. Le chemin est relatif à la racine de la session, par ex. \"index.html\", \"assets/style.css\".\nSert à persister les artefacts de design (HTML/CSS/JS) dans le système de fichiers ; le canvas se rafraîchit en temps réel.\nÀ utiliser uniquement pour les nouveaux fichiers ou quand l'utilisateur demande explicitement un refactoring complet ; préférer file_patch pour modifier les fichiers existants et économiser des tokens.";
"tool.desc.fileWrite.path" = "Chemin relatif, par ex. index.html";
"tool.desc.fileWrite.content" = "Contenu texte UTF-8";
"tool.desc.filePatch" = "Remplacement local d'une partie du contenu d'un fichier existant (SEARCH/REPLACE). À privilégier pour modifier les fichiers existants ; économise considérablement des tokens et accélère la réponse.\nPasse le texte original à rechercher comme `search` et le nouveau contenu comme `replace` ; l'outil localise `search` dans le fichier et le remplace par `replace`.\n`search` doit correspondre de manière unique (0 ou plusieurs correspondances échouent ; ajoute plus de lignes de contexte pour le rendre unique).\nUne chaîne `replace` vide supprime le bloc `search`.";
"tool.desc.filePatch.path" = "Chemin relatif, par ex. index.html";
"tool.desc.filePatch.search" = "Texte original à rechercher et remplacer ; doit être un extrait exact du fichier (indentation/retours à ligne inclus) et unique";
"tool.desc.filePatch.replace" = "Nouveau contenu ; chaîne vide supprime le bloc search";
"tool.desc.fileRead" = "Lire un fichier du répertoire de travail de la session, en renvoyant le contenu texte UTF-8.";
"tool.desc.fileRead.path" = "Chemin relatif";
"tool.desc.fileList" = "Lister tous les fichiers du répertoire de travail de la session (y compris les sous-répertoires), en renvoyant un tableau JSON.";
"tool.desc.fileRemove" = "Supprimer un fichier.";
"tool.desc.fileRemove.path" = "Chemin relatif";
"tool.desc.fileMkdir" = "Créer un sous-répertoire (prend en charge les chemins imbriqués).";
